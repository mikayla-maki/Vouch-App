# One domain, two jobs: WebSocket upgrades go to the relay, everything
# else is the static site. Certificates come from Let's Encrypt,
# automatically; the only configuration is the domain (from .env).
{$VOUCH_RELAY_DOMAIN}

@websocket {
	header Connection *Upgrade*
	header Upgrade websocket
}
reverse_proxy @websocket relay:9443

root * /srv/site
file_server
